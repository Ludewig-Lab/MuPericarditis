ordX <- names(colPal)
# Violin plots per cluster
plots <- lapply(genes_sel, function(gene) {
VlnPlot(
object = seuratM,
features = gene,
cols = colPal, alpha = 0.05
) + scale_x_discrete(limits=ordX)
})
for (p in plots) print(p)
# Violin plot per cluster split by condition
plots <- lapply(genes_sel, function(gene) {
VlnPlot(
object = seuratM,
features = gene,
cols = c("#D3D3D3", "#B45B5C"), split.by = "cond", split.plot = T, alpha = 0.1
) + scale_x_discrete(limits=ordX)
})
