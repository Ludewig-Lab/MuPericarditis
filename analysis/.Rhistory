## ----------------------------
## 1. Define desired cluster order
## ----------------------------
ordVec <- c(
"Cxcl13 CoverCells",
"Ccl19 FRCs",
"Col11 Fibroblasts",
"Dpp4 Fibroblasts",
"Fat4 Fibroblasts",
"Bmp4 Fibroblasts",
"Ccl11 Fibroblasts",
"Tcf21 Fibroblasts"
)
## ----------------------------
## 2. Set identities and enforce order
## ----------------------------
Idents(seuratFB) <- seuratFB$FBclusterLabel
Idents(seuratFB) <- factor(Idents(seuratFB), levels = ordVec)
## ----------------------------
## 3. Marker genes
## ----------------------------
selMarker <- c(
"Pdgfra", "Pdpn", "Cxcl13", "Ccl19", "Ccl11",
"Tcf21", "Bmp4", "Col11a1", "Dpp4", "Fat4"
)
## ----------------------------
## 4. Map gene IDs → full gene names
## ----------------------------
genes <- data.frame(gene = rownames(seuratFB)) %>%
dplyr::mutate(geneID = gsub(".*\\.", "", gene)) %>%
dplyr::filter(geneID %in% selMarker) %>%
dplyr::arrange(factor(geneID, levels = rev(selMarker)))
## ----------------------------
## 5. DotPlot
## ----------------------------
DotPlot(
object        = seuratFB,
features      = genes$gene,
cols          = c("#2C3E50", "#F1E6A1"),
col.min       = -2.5,
col.max       =  2.5,
dot.min       = 0,
dot.scale     = 6,
cluster.idents = TRUE,
scale         = TRUE,
scale.by      = "radius"
) +
coord_flip() +
scale_x_discrete(
breaks = genes$gene,
labels = genes$geneID
) +
scale_y_discrete(
limits = ordVec
) +
theme(
axis.text.x = element_text(angle = 90)
)
